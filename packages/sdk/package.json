{
  "name": "@firemap/sdk",
  "version": "0.1.0",
  "description": "Type-safe Firestore ODM with decorators, validation, and code generation",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "firestore",
    "firebase",
    "odm",
    "typescript",
    "decorators",
    "schema",
    "validation"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "firebase": ">=10.0.0",
    "firebase-admin": ">=12.0.0"
  },
  "peerDependenciesMeta": {
    "firebase": {
      "optional": true
    },
    "firebase-admin": {
      "optional": true
    }
  },
  "dependencies": {
    "@firemap/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "firebase": "^11.0.0",
    "firebase-admin": "^13.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
